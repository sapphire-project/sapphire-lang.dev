---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import RunnableSnippet from '../components/RunnableSnippet.astro';

const snippetHello = `print "Hello from Sapphire!"
who = "world"
print "Hello, #{who}!"`;
const snippetValues = `n = 7
pi = 3
label = "answer"
print "#{label}: #{n + pi}"`;
const snippetMethods = `def double(x: Int) -> Int {
  x * 2
}

print double(21)`;
const snippetClass = `class Counter {
  attr count = 0

  def tick() {
    self.count = self.count + 1
  }
}

c = Counter.new()
c.tick()
c.tick()
print "count is #{c.count}"`;
const snippetBlocks = `nums = [1, 2, 3, 4]
squares = nums.map { |n| n * n }
sum = nums.reduce(0) { |acc, n| acc + n }
print "squares: #{squares}"
print "sum: #{sum}"`;
const snippetTypes = `def clamp(value: Int, min: Int, max: Int) -> Int {
  if value < min { min }
  elsif value > max { max }
  else { value }
}

print clamp(12, 0, 10)`;
const snippetErrors = `def boom() {
  raise "something went wrong"
}

begin
  boom()
rescue e
  print "caught: #{e}"
end`;

const snippetInheritance = `class Shape {
  attr color = "red"

  def area() { 0 }

  def describe() {
    "A #{self.color} shape"
  }
}

class Rectangle < Shape {
  attr width: Int
  attr height: Int

  def area() {
    self.width * self.height
  }

  def describe() {
    super.describe() + " (#{self.width}x#{self.height})"
  }
}

r = Rectangle.new(width: 4, height: 5)
print r.describe()   # A red shape (4x5)
print r.area()       # 20
print r.is_a?(Shape) # true`;
const snippetTypesExtended = `# Annotations are optional — add them where you want safety

def clamp(value: Int, min: Int, max: Int) -> Int {
  if value < min {
    min
  } elsif value > max {
    max
  } else {
    value
  }
}

print clamp(5, 1, 10)   # 5
print clamp(-3, 1, 10)  # 1
print clamp(99, 1, 10)  # 10

def abs(n: Int) -> Int {
  return -n if n < 0
  n
}

def factorial(n: Int) -> Int {
  return 1 if n <= 1
  n * factorial(n - 1)
}

print factorial(6)  # 720`;
const snippetErrorsExtended = `# raise / begin / rescue — clean and composable

def parse_age(s: String) -> Int {
  age = s.to_i
  raise "age must be positive" if age <= 0
  age
}

begin
  print parse_age("25")  # 25
  print parse_age("0")   # raises
rescue e
  print "bad input: #{e}"
end

# Inline rescue inside a function body
def safe_divide(a: Int, b: Int) -> Int {
  a / b
rescue e
  print "cannot divide by zero"
  0
}

print safe_divide(10, 2)  # 5
print safe_divide(10, 0)  # 0`;

---

<Base
  title="Tutorial — Sapphire"
  description="A short guided tour of Sapphire: syntax, classes, blocks, types, and errors — with runnable examples in your browser."
>
  <Nav />
  <main class="min-h-screen pt-24 pb-20 px-6">
    <article class="mx-auto max-w-3xl">
      <header class="mb-10">
        <h1 class="text-3xl font-bold text-white tracking-tight">Tutorial</h1>
        <p class="mt-2 text-sm text-slate-500">
          Browser runtime: <span id="wasm-status" class="text-slate-500">loading…</span>
        </p>
        <p class="mt-4 text-slate-400 leading-relaxed">
          Sapphire is a small, Ruby-inspired language with objects, blocks, and optional type annotations.
          This page walks through the basics; each runnable snippet uses the same WASM engine as the
          <a href="/try" class="text-indigo-400 hover:text-indigo-300 underline underline-offset-2">playground</a>.
        </p>
        <nav aria-label="On this page" class="mt-8 rounded-lg border border-white/10 bg-white/[0.03] p-4">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 mb-2">On this page</p>
          <ul class="text-sm text-slate-400 space-y-1.5 columns-1 sm:columns-2 gap-x-6">
            <li><a href="#hello" class="hover:text-white">Hello</a></li>
            <li><a href="#values" class="hover:text-white">Values</a></li>
            <li><a href="#methods" class="hover:text-white">Methods</a></li>
            <li><a href="#classes" class="hover:text-white">Classes</a></li>
            <li><a href="#inheritance" class="hover:text-white">Inheritance</a></li>
            <li><a href="#blocks" class="hover:text-white">Blocks</a></li>
            <li><a href="#types" class="hover:text-white">Types</a></li>
            <li><a href="#errors" class="hover:text-white">Errors</a></li>
            <li><a href="#next" class="hover:text-white">Next steps</a></li>
          </ul>
        </nav>
      </header>

      <section id="hello" class="scroll-mt-28 mb-16">
        <h2 class="text-xl font-semibold text-white mb-3">Hello, Sapphire</h2>
        <p class="text-slate-400 leading-relaxed mb-4">
          <code class="text-slate-300">print</code> writes a line. Double-quoted strings can interpolate with
          <code class="text-slate-300">#{}</code> — same idea as Ruby.
        </p>
        <RunnableSnippet id="hello" code={snippetHello} filename="hello.spr" rows={6} />
      </section>

      <section id="values" class="scroll-mt-28 mb-16">
        <h2 class="text-xl font-semibold text-white mb-3">Values and variables</h2>
        <p class="text-slate-400 leading-relaxed mb-4">
          Assign with <code class="text-slate-300">=</code>. Types are often inferred; you can mix numbers and strings in messages.
        </p>
        <RunnableSnippet id="values" code={snippetValues} filename="values.spr" rows={6} />
      </section>

      <section id="methods" class="scroll-mt-28 mb-16">
        <h2 class="text-xl font-semibold text-white mb-3">Methods</h2>
        <p class="text-slate-400 leading-relaxed mb-4">
          Define functions with <code class="text-slate-300">def</code>. The last expression is the return value unless you use
          <code class="text-slate-300">return</code>. Annotations like <code class="text-slate-300">-&gt; Int</code> document intent and help the type checker.
        </p>
        <RunnableSnippet id="methods" code={snippetMethods} filename="methods.spr" rows={8} />
      </section>

      <section id="classes" class="scroll-mt-28 mb-16">
        <h2 class="text-xl font-semibold text-white mb-3">Classes</h2>
        <p class="text-slate-400 leading-relaxed mb-4">
          <code class="text-slate-300">class</code> introduces a type. <code class="text-slate-300">attr</code> declares state;
          <code class="text-slate-300">.new</code> constructs an instance. Inside methods, <code class="text-slate-300">self</code> is the receiver.
        </p>
        <RunnableSnippet id="classes" code={snippetClass} filename="counter.spr" rows={12} />
      </section>

      <section id="inheritance" class="scroll-mt-28 mb-16">
        <h2 class="text-xl font-semibold text-white mb-3">Inheritance</h2>
        <p class="text-slate-400 leading-relaxed mb-4">
          Subclasses use <code class="text-slate-300">&lt; Parent</code>. Call overridden hooks with <code class="text-slate-300">super</code>.
          Run the example, then try changing dimensions or <code class="text-slate-300">color</code> and run again.
        </p>
        <RunnableSnippet id="inheritance" code={snippetInheritance} filename="shapes.spr" rows={18} />
      </section>

      <section id="blocks" class="scroll-mt-28 mb-16">
        <h2 class="text-xl font-semibold text-white mb-3">Blocks and iterators</h2>
        <p class="text-slate-400 leading-relaxed mb-4">
          Arrays support familiar iterators: <code class="text-slate-300">map</code>, <code class="text-slate-300">each</code>,
          <code class="text-slate-300">reduce</code>, and friends. Blocks use <code class="text-slate-300">|x|</code> parameters.
        </p>
        <RunnableSnippet id="blocks" code={snippetBlocks} filename="blocks.spr" rows={10} />
      </section>

      <section id="types" class="scroll-mt-28 mb-16">
        <h2 class="text-xl font-semibold text-white mb-3">Optional types</h2>
        <p class="text-slate-400 leading-relaxed mb-4">
          You can annotate parameters and return types where it helps clarity. Omit them where inference is enough.
        </p>
        <RunnableSnippet id="types" code={snippetTypes} filename="types.spr" rows={10} />
        <p class="text-slate-400 leading-relaxed mt-6 mb-4">More patterns: recursion, guards, and multi-branch returns.</p>
        <RunnableSnippet id="types-extended" code={snippetTypesExtended} filename="math.spr" rows={22} />
      </section>

      <section id="errors" class="scroll-mt-28 mb-16">
        <h2 class="text-xl font-semibold text-white mb-3">Errors</h2>
        <p class="text-slate-400 leading-relaxed mb-4">
          Raise with <code class="text-slate-300">raise</code>. Handle failures with <code class="text-slate-300">begin</code> /
          <code class="text-slate-300">rescue</code>. You can also attach <code class="text-slate-300">rescue</code> to a method body for small scopes.
        </p>
        <RunnableSnippet id="errors" code={snippetErrors} filename="errors.spr" rows={10} />
        <p class="text-slate-400 leading-relaxed mt-6 mb-4">Parsing with validation, <code class="text-slate-300">begin</code>/<code class="text-slate-300">rescue</code>, and inline <code class="text-slate-300">rescue</code> on a method.</p>
        <RunnableSnippet id="errors-extended" code={snippetErrorsExtended} filename="errors-full.spr" rows={22} />
      </section>

      <section id="next" class="scroll-mt-28 mb-8">
        <h2 class="text-xl font-semibold text-white mb-3">Next steps</h2>
        <ul class="list-disc list-inside text-slate-400 space-y-2 leading-relaxed">
          <li>Open the <a href="/try" class="text-indigo-400 hover:text-indigo-300 underline underline-offset-2">playground</a> for a blank editor and the full keyboard shortcuts.</li>
          <li>Follow <a href="/#install" class="text-indigo-400 hover:text-indigo-300 underline underline-offset-2">Install</a> on the home page to run Sapphire locally.</li>
          <li>Browse the <a href="https://github.com/sapphire-project/sapphire" class="text-indigo-400 hover:text-indigo-300 underline underline-offset-2">GitHub repository</a> for the compiler, stdlib, and issues.</li>
        </ul>
      </section>
    </article>
  </main>
  <Footer />

  <script>
    import { getRunSapphire } from '../lib/sapphire-wasm';

    function renderOutput(el: HTMLElement, text: string, isError: boolean) {
      el.innerHTML = '';
      el.className =
        'px-5 py-3 font-mono text-sm leading-relaxed bg-[#0a0a0f] min-h-[3.5rem] ' +
        (isError ? 'text-red-400' : 'text-slate-200');
      if (!text) {
        const empty = document.createElement('span');
        empty.className = 'text-slate-600 text-xs';
        empty.textContent = '(no output)';
        el.appendChild(empty);
        return;
      }
      const pre = document.createElement('pre');
      pre.className = isError
        ? 'whitespace-pre-wrap break-words text-red-400'
        : 'whitespace-pre-wrap break-words';
      pre.textContent = text;
      el.appendChild(pre);
    }

    function setRunning(btn: HTMLButtonElement, running: boolean) {
      btn.disabled = running;
      const icon = btn.querySelector('[data-run-icon]');
      const spin = btn.querySelector('[data-run-spinner]');
      icon?.classList.toggle('hidden', running);
      spin?.classList.toggle('hidden', !running);
    }

    (async () => {
      const wasmStatus = document.getElementById('wasm-status');
      let runSapphire: Awaited<ReturnType<typeof getRunSapphire>> | null = null;
      try {
        runSapphire = await getRunSapphire();
        if (wasmStatus) {
          wasmStatus.textContent = 'ready';
          wasmStatus.classList.remove('text-slate-500');
          wasmStatus.classList.add('text-green-400/80');
        }
      } catch (e) {
        if (wasmStatus) {
          wasmStatus.textContent = 'failed to load runtime';
          wasmStatus.classList.add('text-red-400');
        }
        console.error(e);
        return;
      }

      document.querySelectorAll('[data-runnable-snippet]').forEach((rootEl) => {
        const root = rootEl as HTMLElement;
        const editor = root.querySelector('[data-editor]') as HTMLTextAreaElement | null;
        const runBtn = root.querySelector('[data-run-btn]') as HTMLButtonElement | null;
        const outputEl = root.querySelector('[data-output]') as HTMLElement | null;
        if (!editor || !runBtn || !outputEl || !runSapphire) return;

        runBtn.disabled = false;

        runBtn.addEventListener('click', async () => {
          setRunning(runBtn, true);
          await new Promise((r) => setTimeout(r, 0));
          try {
            const result = runSapphire!(editor.value);
            if (result.is_ok()) {
              renderOutput(outputEl, result.output(), false);
            } else {
              renderOutput(outputEl, result.error() ?? 'Unknown error', true);
            }
          } catch (err) {
            renderOutput(outputEl, String(err), true);
          } finally {
            setRunning(runBtn, false);
          }
        });

        editor.addEventListener('keydown', (e) => {
          if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
            e.preventDefault();
            runBtn.click();
          }
          if (e.key === 'Tab') {
            e.preventDefault();
            const start = editor.selectionStart;
            const end = editor.selectionEnd;
            editor.value = editor.value.slice(0, start) + '  ' + editor.value.slice(end);
            editor.selectionStart = editor.selectionEnd = start + 2;
          }
        });
      });
    })();
  </script>
</Base>

---
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-[#0a0a0f]/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-4 sm:px-6">
    <a href="/" class="flex shrink-0 items-center gap-2 text-lg font-semibold tracking-tight text-white">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <polygon points="12,2 22,8 22,16 12,22 2,16 2,8" fill="#6366f1" opacity="0.9" />
        <polygon points="12,5 19,9 19,15 12,19 5,15 5,9" fill="#4338ca" opacity="0.7" />
        <polygon points="12,8 16,10.5 16,13.5 12,16 8,13.5 8,10.5" fill="#818cf8" opacity="0.9" />
      </svg>
      Sapphire
    </a>
    <div class="hidden items-center gap-6 md:flex">
      <a
        href="/#install"
        class="shrink-0 text-sm text-slate-400 transition-colors hover:text-white"
      >Install</a>
      <a
        href="/tutorial"
        class="shrink-0 text-sm text-slate-400 transition-colors hover:text-white"
      >Tutorial</a>
      <a
        href="/try"
        class="shrink-0 text-sm text-slate-400 transition-colors hover:text-white"
      >Try it</a>
      <a
        href="https://github.com/sapphire-project/sapphire"
        target="_blank"
        rel="noopener noreferrer"
        class="flex shrink-0 items-center gap-1.5 rounded-md border border-white/10 bg-white/5 px-3 py-1.5 text-sm text-slate-300 transition-all hover:bg-white/10 hover:text-white"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
          />
        </svg>
        GitHub
      </a>
    </div>
    <button
      type="button"
      class="inline-flex items-center justify-center rounded-md p-2 text-slate-300 transition-colors hover:bg-white/5 hover:text-white md:hidden"
      id="nav-toggle"
      aria-expanded="false"
      aria-controls="nav-mobile"
      aria-label="Open menu"
    >
      <svg
        class="h-6 w-6"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <path d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
  <div
    class="hidden border-t border-white/5 bg-[#0a0a0f]/95 px-4 py-4 backdrop-blur-md md:hidden"
    id="nav-mobile"
  >
    <div class="mx-auto flex max-w-6xl flex-col gap-1 sm:px-2">
      <a
        href="/#install"
        class="rounded-md px-2 py-2.5 text-sm text-slate-300 transition-colors hover:bg-white/5 hover:text-white"
      >Install</a>
      <a
        href="/tutorial"
        class="rounded-md px-2 py-2.5 text-sm text-slate-300 transition-colors hover:bg-white/5 hover:text-white"
      >Tutorial</a>
      <a
        href="/try"
        class="rounded-md px-2 py-2.5 text-sm text-slate-300 transition-colors hover:bg-white/5 hover:text-white"
      >Try it</a>
      <a
        href="https://github.com/sapphire-project/sapphire"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-1 flex w-fit items-center gap-1.5 rounded-md border border-white/10 bg-white/5 px-3 py-2.5 text-sm text-slate-200 transition-all hover:bg-white/10"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
          />
        </svg>
        GitHub
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle');
  const mobile = document.getElementById('nav-mobile');
  if (toggle && mobile) {
    function setOpen(open) {
      mobile.classList.toggle('hidden', !open);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    }
    function isOpen() {
      return !mobile.classList.contains('hidden');
    }
    toggle.addEventListener('click', () => {
      setOpen(!isOpen());
    });
    mobile.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => setOpen(false));
    });
    const mq = window.matchMedia('(min-width: 768px)');
    const closeIfDesktop = () => {
      if (mq.matches) setOpen(false);
    };
    mq.addEventListener('change', closeIfDesktop);
    closeIfDesktop();
  }
</script>

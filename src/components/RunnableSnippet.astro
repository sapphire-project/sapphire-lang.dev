---
interface Props {
  id: string;
  code: string;
  filename?: string;
  rows?: number;
}

const { id, code, filename = 'snippet.spr', rows = 28 } = Astro.props;

const lineCount = code.replace(/\s+$/, '').split(/\r?\n/).length;
const rowCount = Math.min(rows, Math.max(lineCount, 2));
---

<div
  class="runnable-snippet my-8 rounded-xl border border-white/10 overflow-hidden shadow-xl shadow-black/40 not-prose"
  data-runnable-snippet
  data-snippet-id={id}
>
  <div class="flex items-center justify-between gap-3 px-4 py-3 border-b border-white/5 bg-[#0d0d14]">
    <div class="flex items-center gap-1.5 min-w-0">
      <span class="h-3 w-3 shrink-0 rounded-full bg-red-500/70" aria-hidden="true"></span>
      <span class="h-3 w-3 shrink-0 rounded-full bg-yellow-500/70" aria-hidden="true"></span>
      <span class="h-3 w-3 shrink-0 rounded-full bg-green-500/70" aria-hidden="true"></span>
      <span class="ml-2 truncate text-xs text-slate-500 font-mono">{filename}</span>
    </div>
    <button
      type="button"
      data-run-btn
      disabled
      class="shrink-0 flex items-center gap-2 rounded-lg bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white shadow-lg shadow-indigo-600/25 hover:bg-indigo-500 disabled:opacity-40 disabled:cursor-not-allowed transition-all"
    >
      <svg data-run-icon width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M5 3l14 9-14 9V3z"></path>
      </svg>
      <svg
        data-run-spinner
        class="hidden animate-spin"
        width="10"
        height="10"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        aria-hidden="true"
      >
        <path
          d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"
        ></path>
      </svg>
      Run
    </button>
  </div>
  <div class="grid border-b border-white/5">
    <pre
      class="language-ruby col-start-1 row-start-1 m-0 min-h-0 min-w-0 overflow-auto px-5 py-4 text-sm leading-relaxed pointer-events-none [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden"
      aria-hidden="true"
    ><code class="language-ruby block min-h-full" data-syntax-highlight set:text={code}></code></pre>
    <textarea
      data-editor
      spellcheck="false"
      autocorrect="off"
      autocapitalize="off"
      rows={rowCount}
      class="col-start-1 row-start-1 z-10 min-h-0 min-w-0 w-full resize-y overflow-auto bg-transparent px-5 py-4 font-mono text-sm text-transparent outline-none leading-relaxed caret-indigo-400 block"
      set:text={code}
    />
  </div>
  <div
    data-output
    class="px-5 py-3 font-mono text-sm leading-relaxed bg-[#0a0a0f] min-h-[3.5rem] text-slate-600 text-xs"
  >
    Press Run to execute this snippet. ⌘↵ runs from the editor.
  </div>
</div>

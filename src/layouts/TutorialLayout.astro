---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/runnable-prism.css';

interface Props {
  title?: string;
  description?: string;
  pageTitle?: string;
  pageDescription?: string;
  pageId?: string;
}

const {
  title = 'Tutorial — Sapphire',
  description = 'A guided tour of Sapphire syntax, classes, blocks, types, pattern matching, interfaces, and error handling.',
  pageTitle = 'Tutorial',
  pageDescription = 'Sapphire is a small, Ruby-inspired language with objects, blocks, and optional type annotations.',
  pageId = 'basics',
} = Astro.props as Props;

const tutorialPages = [
  { id: 'basics', title: 'Basics', href: '/tutorial/' },
  { id: 'classes', title: 'Classes and objects', href: '/tutorial/classes-and-objects/' },
  { id: 'built-ins', title: 'Built-in types', href: '/tutorial/built-in-types/' },
  { id: 'control-flow', title: 'Control flow', href: '/tutorial/control-flow/' },
  { id: 'gradual-typing', title: 'Gradual typing', href: '/tutorial/gradual-typing/' },
  { id: 'error-handling', title: 'Error handling', href: '/tutorial/error-handling/' },
];

const currentIndex = Math.max(0, tutorialPages.findIndex((page) => page.id === pageId));
const previousPage = currentIndex > 0 ? tutorialPages[currentIndex - 1] : null;
const nextPage = currentIndex < tutorialPages.length - 1 ? tutorialPages[currentIndex + 1] : null;
---

<Base title={title} description={description}>
  <Nav />
  <main class="min-h-screen pt-24 pb-20 px-6">
    <article class="tutorial-prose mx-auto max-w-3xl">
      <header class="mb-10">
        <h1 class="text-3xl font-bold text-white tracking-tight">{pageTitle}</h1>
        <p class="mt-2 text-sm text-slate-500">
          Browser runtime: <span id="wasm-status" class="text-slate-500">loading…</span>
        </p>
        <p class="mt-4 text-slate-400 leading-relaxed">
          {pageDescription} Each runnable snippet uses the same WASM engine as the
          <a href="/try" class="text-indigo-400 hover:text-indigo-300 underline underline-offset-2">playground</a>.
        </p>
        <nav aria-label="Tutorial sections" class="tutorial-nav mt-8 rounded-lg border border-white/10 bg-white/[0.03] p-4">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 mb-3">Tutorial sections</p>
          <ul class="grid gap-2 text-sm sm:grid-cols-2">
            {tutorialPages.map((page) => (
              <li>
                <a
                  href={page.href}
                  aria-current={page.id === pageId ? 'page' : undefined}
                  class:list={[
                    'block rounded-md px-3 py-2 transition-colors',
                    page.id === pageId
                      ? 'bg-indigo-500/15 text-indigo-200 ring-1 ring-indigo-400/25'
                      : 'text-slate-400 hover:bg-white/5 hover:text-white',
                  ]}
                >
                  {page.title}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </header>

      <slot />

      <nav aria-label="Tutorial page navigation" class="tutorial-nav mt-14 grid gap-3 border-t border-white/10 pt-8 sm:grid-cols-2">
        {previousPage ? (
          <a
            href={previousPage.href}
            class="rounded-lg border border-white/10 bg-white/[0.03] p-4 text-sm text-slate-400 transition-colors hover:border-indigo-400/30 hover:bg-indigo-500/10 hover:text-white"
          >
            <span class="block text-xs uppercase tracking-wide text-slate-500">Previous</span>
            {previousPage.title}
          </a>
        ) : (
          <span></span>
        )}
        {nextPage && (
          <a
            href={nextPage.href}
            class="rounded-lg border border-white/10 bg-white/[0.03] p-4 text-right text-sm text-slate-400 transition-colors hover:border-indigo-400/30 hover:bg-indigo-500/10 hover:text-white"
          >
            <span class="block text-xs uppercase tracking-wide text-slate-500">Next</span>
            {nextPage.title}
          </a>
        )}
      </nav>
    </article>
  </main>
  <Footer />

  <script>
    import { getRunSapphire } from '../runtime/sapphire-wasm';
    import Prism from 'prismjs';
    import 'prismjs/components/prism-ruby';

    function bindRubyHighlight(root: HTMLElement, editor: HTMLTextAreaElement) {
      const codeEl = root.querySelector('[data-syntax-highlight]');
      const preEl = codeEl?.parentElement;
      if (!codeEl || !(codeEl instanceof HTMLElement) || !preEl) return;

      const sync = () => {
        codeEl.textContent = editor.value;
        Prism.highlightElement(codeEl);
      };

      const syncScroll = () => {
        preEl.scrollTop = editor.scrollTop;
        preEl.scrollLeft = editor.scrollLeft;
      };

      sync();
      editor.addEventListener('input', sync);
      editor.addEventListener('scroll', syncScroll);
    }

    function renderOutput(el: HTMLElement, text: string, isError: boolean) {
      el.innerHTML = '';
      el.className =
        'px-5 py-3 font-mono text-sm leading-relaxed bg-[#0a0a0f] min-h-[3.5rem] ' +
        (isError ? 'text-red-400' : 'text-slate-200');
      if (!text) {
        const empty = document.createElement('span');
        empty.className = 'text-slate-600 text-xs';
        empty.textContent = '(no output)';
        el.appendChild(empty);
        return;
      }
      const pre = document.createElement('pre');
      pre.className = isError
        ? 'whitespace-pre-wrap break-words text-red-400'
        : 'whitespace-pre-wrap break-words';
      pre.textContent = text;
      el.appendChild(pre);
    }

    function setRunning(btn: HTMLButtonElement, running: boolean) {
      btn.disabled = running;
      const icon = btn.querySelector('[data-run-icon]');
      const spin = btn.querySelector('[data-run-spinner]');
      icon?.classList.toggle('hidden', running);
      spin?.classList.toggle('hidden', !running);
    }

    (async () => {
      const wasmStatus = document.getElementById('wasm-status');
      let runSapphire: Awaited<ReturnType<typeof getRunSapphire>> | null = null;
      try {
        runSapphire = await getRunSapphire();
        if (wasmStatus) {
          wasmStatus.textContent = 'ready';
          wasmStatus.classList.remove('text-slate-500');
          wasmStatus.classList.add('text-green-400/80');
        }
      } catch (e) {
        if (wasmStatus) {
          wasmStatus.textContent = 'failed to load runtime';
          wasmStatus.classList.add('text-red-400');
        }
        console.error(e);
        return;
      }

      document.querySelectorAll('[data-runnable-snippet]').forEach((rootEl) => {
        const root = rootEl as HTMLElement;
        const editor = root.querySelector('[data-editor]') as HTMLTextAreaElement | null;
        const runBtn = root.querySelector('[data-run-btn]') as HTMLButtonElement | null;
        const outputEl = root.querySelector('[data-output]') as HTMLElement | null;
        if (!editor || !runBtn || !outputEl || !runSapphire) return;

        runBtn.disabled = false;

        bindRubyHighlight(root, editor);

        runBtn.addEventListener('click', async () => {
          setRunning(runBtn, true);
          await new Promise((r) => setTimeout(r, 0));
          try {
            const result = runSapphire!(editor.value);
            if (result.is_ok()) {
              renderOutput(outputEl, result.output(), false);
            } else {
              renderOutput(outputEl, result.error() ?? 'Unknown error', true);
            }
          } catch (err) {
            renderOutput(outputEl, String(err), true);
          } finally {
            setRunning(runBtn, false);
          }
        });

        editor.addEventListener('keydown', (e) => {
          if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
            e.preventDefault();
            runBtn.click();
          }
          if (e.key === 'Tab') {
            e.preventDefault();
            const start = editor.selectionStart;
            const end = editor.selectionEnd;
            editor.value = editor.value.slice(0, start) + '  ' + editor.value.slice(end);
            editor.selectionStart = editor.selectionEnd = start + 2;
          }
        });
      });
    })();
  </script>
</Base>
